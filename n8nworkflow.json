    {
      "parameters": {
        "jsCode": "// Tüm sheet satırlarını ve yeni mail trigger verisini al\nconst allRows = $('Get previous messages').all();\nconst newMail = $('Gmail Trigger').item.json;\nconst messageId = newMail.id || '';\nconst triggerEmail = newMail.From || '';\n\n// Dedup: aynı Mesaj ID daha önce işlenmişse durdur\nconst alreadyProcessed = allRows.some(r => r.json && r.json['Mesaj ID'] === messageId && messageId !== '');\nif (alreadyProcessed) {\n  return [];\n}\n\n// Aynı email'den son 5 etkileşimi bul, kronolojik sırala (eski → yeni)\nconst previous = allRows\n  .filter(r => r.json && r.json.Email === triggerEmail)\n  .sort((a, b) => new Date(b.json.Tarih || 0) - new Date(a.json.Tarih || 0))\n  .slice(0, 5)\n  .reverse();\n\nlet contextStr = '';\nif (previous.length > 0) {\n  contextStr = 'ÖNCEKİ YAZIŞMALAR (eski → yeni):\\n';\n  previous.forEach((row, i) => {\n    const tarih = row.json.Tarih || 'tarih yok';\n    const mesaj = row.json.Mesaj || '';\n    const yanit = row.json['Gonderilen Yanit'] || row.json['AI Taslak'] || '(henüz yanıtlanmadı)';\n    contextStr += `${i+1}. [${tarih}]\\n   Müşteri: \"${mesaj}\"\\n   Bizim yanıtımız: \"${yanit}\"\\n\\n`;\n  });\n}\n\n// İşletme bilgileri (Load Ayarlar'dan)\nconst settings = $('Load Ayarlar').first()?.json || {};\nlet businessSection = '';\nconst hasAnyBusiness = settings.sirket_adi || settings.urun_hizmet || settings.calisma_saatleri || settings.iade_politikasi || settings.kargo_bilgisi || settings.ek_bilgi;\nif (hasAnyBusiness) {\n  businessSection = 'İŞLETME BİLGİLERİ:\\n';\n  if (settings.sirket_adi) businessSection += `- Şirket: ${settings.sirket_adi}\\n`;\n  if (settings.urun_hizmet) businessSection += `- Ürün/Hizmet: ${settings.urun_hizmet}\\n`;\n  if (settings.calisma_saatleri) businessSection += `- Çalışma Saatleri: ${settings.calisma_saatleri}\\n`;\n  if (settings.iade_politikasi) businessSection += `- İade Politikası: ${settings.iade_politikasi}\\n`;\n  if (settings.kargo_bilgisi) businessSection += `- Kargo: ${settings.kargo_bilgisi}\\n`;\n  if (settings.ek_bilgi) businessSection += `- Ek Bilgi: ${settings.ek_bilgi}\\n`;\n  businessSection += '\\n';\n}\nconst yanitTonu = settings.yanit_tonu || 'samimi ve profesyonel';\n\n// SSS (Load SSS'ten)\nconst faqRows = $('Load SSS').all().map(r => r.json).filter(r => r && r.Soru && r.Cevap);\nlet faqSection = '';\nif (faqRows.length > 0) {\n  faqSection = 'SIK SORULAN SORULAR:\\n';\n  faqRows.forEach(f => { faqSection += `S: ${f.Soru}\\nC: ${f.Cevap}\\n\\n`; });\n}\n\nreturn [{\n  json: {\n    businessSection,\n    faqSection,\n    yanitTonu,\n    context: contextStr,\n    newMessage: newMail.snippet || '',\n    messageId: messageId,\n    threadId: newMail.threadId || '',\n    fromEmail: triggerEmail,\n    date: new Date().toISOString(),\n    previousCount: previous.length\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
