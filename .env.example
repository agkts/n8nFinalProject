# n8n instance'inin public domain'i (Dokploy'dan atanacak)
N8N_HOST=n8n.yourdomain.com
N8N_BASE_URL=https://n8n.yourdomain.com

# Guvenlik - N8N_ENCRYPTION_KEY bir kez belirlendikten sonra DEGISTIRILMEMELI
N8N_ENCRYPTION_KEY=cok-gizli-rastgele-bir-anahtar-buraya
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=guclu-sifre-buraya

# Zaman dilimi
TIMEZONE=Europe/Istanbul
