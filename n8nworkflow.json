        "jsCode": "// Ayarlar sayfasından tek satır oku\nconst settingsRow = $('Read Ayarlar').first()?.json || {};\n// SSS sayfasından tüm satırları oku, boş olanları at\nconst faqRows = $('Read SSS').all()\n  .map(r => r.json)\n  .filter(r => r && r.Soru && r.Cevap);\n\nreturn [{\n  json: {\n    settings: {\n      sirket_adi: settingsRow.sirket_adi || '',\n      urun_hizmet: settingsRow.urun_hizmet || '',\n      calisma_saatleri: settingsRow.calisma_saatleri || '',\n      iade_politikasi: settingsRow.iade_politikasi || '',\n      kargo_bilgisi: settingsRow.kargo_bilgisi || '',\n      yanit_tonu: settingsRow.yanit_tonu || '',\n      ek_bilgi: settingsRow.ek_bilgi || ''\n    },\n    faqs: faqRows.map(r => ({ soru: r.Soru, cevap: r.Cevap }))\n  }\n}];"
      },
